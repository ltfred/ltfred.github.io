&lt;ul&gt;
&lt;li&gt;&lt;a href=&quot;https://github.com.cnpmjs.org&quot;&gt;https://github.com.cnpmjs.org&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;&lt;a href=&quot;https://hub.fastgit.org&quot;&gt;https://hub.fastgit.org&lt;/a&gt;&lt;/li&gt;
&lt;/ul&gt;
